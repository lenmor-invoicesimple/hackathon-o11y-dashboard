# Datadog API credentials
# DD_API_KEY: from https://app.datadoghq.com/organization-settings/api-keys
# DD_APP_KEY: from https://app.datadoghq.com/organization-settings/application-keys
DD_API_KEY=
DD_APP_KEY=

# Mezmo Service Key — from Mezmo Settings → Organization → API Keys → Service Keys
# Auth format used: "Authorization: Token <key>"
MEZMO_SERVICE_KEY=

# Sentry Personal Token — sentry.io → Settings → Account → API → Personal Tokens
# Scopes needed: alerts:read, event:read, project:read
SENTRY_AUTH_TOKEN=
